// tmp_schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Hero {
  id          String   @id @default(cuid())
  title_en    String
  title_id    String
  subtitle_en String
  subtitle_id String
  cta_en      String   @default("View My Work")
  cta_id      String   @default("Lihat Karya Saya")
  badge_en    String   @default("Available for Freelance")
  badge_id    String   @default("Tersedia untuk Freelance")
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model About {
  id             String   @id @default(cuid())
  description_en String   @db.Text
  description_id String   @db.Text
  image          String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Skill {
  id        String      @id @default(cuid())
  name      String
  level     Int         @default(80)
  category  String      @default("Technical")
  icon      String?
  published Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Project {
  id             String   @id @default(cuid())
  title_en       String
  title_id       String
  description_en String   @db.Text
  description_id String   @db.Text
  image          String?
  tech_stack     String[]
  link           String?
  github         String?
  category       String   @default("Web")
  featured       Boolean  @default(false)
  published      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Experience {
  id             String    @id @default(cuid())
  title_en       String
  title_id       String
  company        String
  location       String?
  start_date     DateTime
  end_date       DateTime?
  description_en String    @db.Text
  description_id String    @db.Text
  published      Boolean   @default(true)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Social {
  id        String   @id @default(cuid())
  name      String
  link      String
  icon      String?
  published Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  email     String
  phone     String?
  location  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([path])
}

enum Role {
  ADMIN
  SUPER_ADMIN
}
